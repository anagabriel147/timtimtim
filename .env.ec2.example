# Copiar para .env.ec2 na PRÓPRIA instância EC2 (via SSH) e preencher com
# valores reais. Nunca commitar o .env.ec2 preenchido, nunca colocar estes
# valores em user-data/deploy.sh (ver comentário no topo de deploy.sh).

POSTGRES_USER=timtim_admin
POSTGRES_PASSWORD=troque-por-uma-senha-forte
POSTGRES_DB=timtim

# Gerar com: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=troque-por-uma-chave-forte-e-aleatoria
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Preencher com o Elastic IP (ou o domínio, depois de configurar HTTPS).
# Roteamento é por path (/api/*) no mesmo host — ver nginx/ec2.conf — então
# CORS_ORIGINS não é estritamente necessário pro app funcionar (same-origin),
# mas mantém defesa em profundidade pra qualquer cliente não-browser.
CORS_ORIGINS=http://SEU_ELASTIC_IP
NEXT_PUBLIC_API_URL=http://SEU_ELASTIC_IP/api

# t4g.nano (0.5GB RAM) — usar 1. t3.micro (1GB RAM) — 2 já é razoável.
API_WEB_CONCURRENCY=2
