# Copiar para .env.prod e preencher com valores reais antes de rodar
# docker-compose.prod.yml. Nunca commitar o .env.prod preenchido.

POSTGRES_USER=timtim_admin
POSTGRES_PASSWORD=troque-por-uma-senha-forte
POSTGRES_DB=timtim

# Gerar com: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=troque-por-uma-chave-forte-e-aleatoria
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Domínio(s) do frontend que podem chamar a API, separados por vírgula
CORS_ORIGINS=http://localhost:3000

# URL pública da API — vira parte do bundle do browser em build time
NEXT_PUBLIC_API_URL=http://localhost:8000
